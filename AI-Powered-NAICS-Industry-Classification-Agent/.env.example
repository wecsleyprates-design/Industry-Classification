OPENAI_API_KEY=your-openai-api-key-here

# Optional — enables Companies House UK SIC lookup (free key)
# Get one at: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=your-companies-house-api-key-here

# Redshift connection (for live OpenCorporates/Equifax/ZoomInfo/Liberty Data)
REDSHIFT_HOST=your-cluster.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=dev
REDSHIFT_USER=your_username
REDSHIFT_PASSWORD=your_password
