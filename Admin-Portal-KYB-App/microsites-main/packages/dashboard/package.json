{
	"name": "microsite-dashboard-app",
	"version": "0.0.1",
	"engines": {
		"node": "24.x",
		"npm": ">=11"
	},
	"scripts": {
		"start": "vite --strictPort",
		"start:doppler": "doppler run -- npm run start",
		"build": "tsc && vite build",
		"build:doppler": "doppler run -- npm run build",
		"mfbuild": "tsc && vite build --watch",
		"preview": "vite preview --port 5176 --strictPort",
		"preview:doppler": "doppler run -- npm run preview",
		"preview:mf": "concurrently \" npm run mfbuild \" \" npm run preview \"",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --ignore-path .prettierignore --write \"**/*.+(ts|tsx|js|jsx|json)\"",
		"test": "jest",
		"test:doppler": "doppler run -- npm run test",
		"release": "standard-version",
		"commit": "cz"
	},
	"dependencies": {
