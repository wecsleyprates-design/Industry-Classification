# Copy this file to secrets.toml (same directory) and fill in real values.
# NEVER commit secrets.toml to git — it is in .gitignore.
#
# Streamlit looks for secrets.toml in these locations (first match wins):
#   1. ~/.streamlit/secrets.toml           (global, all apps)
#   2. <project>/.streamlit/secrets.toml   (project-specific)
#
# For this app the project-specific path is:
#   Industry-Classification/Admin-Portal-KYB-App/.streamlit/secrets.toml

OPENAI_API_KEY = "sk-svcacct-your-key-here"

# Redshift connection (optional — defaults are already hardcoded in app)
# REDSHIFT_HOST     = "worthai-services-redshift-endpoint-..."
# REDSHIFT_DB       = "dev"
# REDSHIFT_USER     = "readonly_all_access"
# REDSHIFT_PASSWORD = "your-password-here"
# REDSHIFT_PORT     = "5439"
