{
	"name": "workflow-service",
	"version": "1.0.0",
	"description": "Workflow Service for Worth-AI",
	"private": true,
	"author": "Worth-AI",
	"license": "MIT",
	"engines": {
		"node": "22.x",
		"npm": ">=10"
	},
	"scripts": {
		"start": "npm run build:clean && cross-env NODE_ENV=production node dist/src/index.js",
		"start:prod": "npm run build:clean && cross-env NODE_ENV=production node dist/src/index.js",
		"start:dev": "cross-env NODE_ENV=development node --inspect=0.0.0.0:9229 --enable-source-maps -r tsconfig-paths/register -r ts-node/register src/index.ts",
		"dev": "nodemon --watch src --watch lib --ext js,ts,json --exec \"npm run start:dev\"",
		"debug": "cross-env NODE_ENV=development node dist/src/index.js",
		"test": "jest --colors --verbose",
		"test:watch": "jest -i --watchAll",
		"test:coverage": "jest -i --coverage --coverageReporters=text-summary --coverageReporters=lcov --passWithNoTests",
		"test:coverage-ci": "jest --coverage --reporters=jest-junit | tee ./coverage.txt",
		"prepare": "husky",
		"commit": "cz",
		"build": "npx tsc",
		"build:clean": "rm -rf dist && npm run build",
		"lint": "eslint . --ext .js --ext .ts",
		"lint:fix": "npm run lint -- --fix",
		"format": "prettier --check \"**/*.+(js|ts|json)\"",
		"format:fix": "prettier --write \"**/*.+(js|ts|json)\"",
		"db": "cross-env-shell db-migrate -m '$INIT_CWD/db/migrations'",
		"db:create": "npm run db db:create",
		"db:drop": "npm run db db:drop",
		"migrate:up": "npm run db up:migrate",
		"migrate:down": "npm run db down:migrate",
		"migrate:create": "npm run db create:migrate",
		"migrate:reset": "npm run db reset:migrate",
		"migrate:docker:up": "docker exec workflow-service doppler run -- npm run db up:migrate --config ./db/dbmrc.ts",
		"migrate:docker:down": "docker exec workflow-service doppler run -- npm run db down:migrate --config ./db/dbmrc.ts",
		"migrate:docker:check": "docker exec workflow-service doppler run -- npm run db check --config ./db/dbmrc.ts",
		"migrate:docker:reset": "docker exec workflow-service doppler run -- npm run db reset:migrate --config ./db/dbmrc.ts",
		"seed:up": "npm run db up:seed",
		"seed:down": "npm run db down:seed",
		"seed:create": "npm run db create:seed",
		"seed:attributes": "cross-env NODE_OPTIONS=\"--import tsx\" tsx db/seeders/attribute-catalog/seed.ts",
		"module:create": "cross-env NODE_OPTIONS=\"--import tsx\" plop module --plopfile=plopfile.ts",
		"route:create": "cross-env NODE_OPTIONS=\"--import tsx\" plop route --plopfile=plopfile.ts"
	},
	"dependencies": {
		"@aws-sdk/client-cognito-identity-provider": "^3.914.0",
		"@joinworth/types": "^0.0.38",
		"@joinworth/worth-core-service": "^1.1.0",
		"@joinworth/worth-core-utils": "^0.2.0",
		"@types/knex": "^0.16.1",
		"aws-jwt-verify": "^5.1.1",
		"axios": "^1.12.2",
		"bcryptjs": "^3.0.2",
		"bull": "^4.16.5",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"crypto-js": "^4.2.0",
		"csv-stringify": "^6.6.0",
		"db-migrate": "^0.11.14",
		"db-migrate-pg": "^1.5.2",
		"dotenv": "^17.2.2",
		"express": "^5.1.0",
		"express-useragent": "^1.0.15",
		"helmet": "^8.1.0",
		"http-errors": "~2.0.0",
		"http-status-codes": "^2.3.0",
		"ioredis": "^5.4.1",
		"jest-junit": "^16.0.0",
		"joi": "^18.0.1",
		"json-logic-js": "^2.0.5",
		"jsonwebtoken": "^9.0.2",
		"kafkajs": "^2.2.4",
		"knex": "^3.1.0",
		"lodash": "^4.17.21",
		"module-alias": "^2.2.3",
		"pg": "^8.16.3",
		"pino": "^9.12.0",
		"pino-http": "^10.5.0",
		"plop": "^4.0.4",
		"supertest": "^7.0.0",
		"swagger-jsdoc": "^6.2.8",
		"swagger-ui-express": "^5.0.1",
		"uuid": "^8.3.2",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.0.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@types/cookie-parser": "^1.4.9",
		"@types/cors": "^2.8.19",
		"@types/crypto-js": "^4.2.2",
		"@types/db-migrate-pg": "~0.0.13",
		"@types/express": "^5.0.3",
		"@types/express-useragent": "~1.0.5",
		"@types/http-errors": "~2.0.5",
		"@types/ioredis": "^5.0.0",
		"@types/jest": "^30.0.0",
		"@types/json-logic-js": "^1.2.1",
		"@types/jsonwebtoken": "~9.0.10",
		"@types/lodash": "^4.17.0",
		"@types/node": "^24.5.2",
		"@types/pg": "^8.15.5",
		"@types/supertest": "^6.0.2",
		"@types/swagger-jsdoc": "^6.0.4",
		"@types/swagger-ui-express": "^4.1.6",
		"@types/uuid": "^9.0.7",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"cross-env": "^10.0.0",
		"cz-conventional-changelog": "^3.3.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"husky": "^9.1.7",
		"jest": "^30.1.3",
		"jiti": "^2.6.0",
		"lint-staged": "^16.1.6",
		"nodemon": "^3.1.10",
		"pino-pretty": "^13.1.1",
		"prettier": "^3.6.2",
		"ts-jest": "^29.4.4",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.20.6",
		"typescript": "^5.9.2"
	},
	"_moduleAliases": {
		"#configs": "dist/src/configs",
		"#constants": "dist/src/constants",
		"#core": "dist/src/core",
		"#database": "dist/src/database",
		"#helpers": "dist/src/helpers",
		"#middlewares": "dist/src/middlewares",
		"#messaging": "dist/src/messaging",
		"#services": "dist/src/services",
		"#types": "dist/src/types",
		"#utils": "dist/src/utils",
		"#lib": "dist/lib",
		"#workers": "dist/src/workers",
		"#api": "dist/src/api",
		"#workflows": "dist/src/api/v1/modules/workflows",
		"#triggers": "dist/src/api/v1/modules/triggers"
	},
	"nodemonConfig": {
		"ignore": [
			"**/__tests__/**",
			"**/*.test.js"
		],
		"delay": 2500
	},
	"overrides": {
		"brace-expansion": "2.0.2"
	},
	"config": {
		"commitizen": {
			"path": "cz-conventional-changelog"
		}
	}
}
