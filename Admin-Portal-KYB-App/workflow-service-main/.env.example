NODE_ENV=development
DOPPLER_CONFIG=development
CONFIG_APP_PORT=3007
SUBDOMAIN=your-subdomain

CONFIG_DB_HOST=localhost
CONFIG_DB_PORT=5432
CONFIG_DB_USER=your-db-user
CONFIG_DB_PASSWORD=your-db-password
CONFIG_DB_NAME=workflow_service_db
CONFIG_DB_MAX_CONNECTIONS=20

CONFIG_WORTH_ADMIN_USER_POOL_ID=us-east-1_WoRtHaDm1n
CONFIG_APPLICANT_USER_POOL_ID=us-east-1_aBcDeFgHi
CONFIG_CUSTOMER_USER_POOL_ID=us-east-1_XyZ123456
CONFIG_WORTH_ADMIN_CLIENT_ID=7q8w9e0r1t2y3u4i5o6p7a8s9d0f1g2h
CONFIG_APPLICANT_CLIENT_ID=1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p
CONFIG_CUSTOMER_CLIENT_ID=3i4o5p6a7s8d9f0g1h2j3k4l5m6n7o8p9q
CONFIG_CASE_BASE_URL=https://cases.example.com
CONFIG_CASE_SERVICE_URL=http://case-service:3003
CONFIG_CASE_API_PREFIX=/api/v1
CONFIG_CASE_HEALTH_PATH=/api/health

CONFIG_LD_INTIALIZATION_TIMEOUT=5000
CONFIG_LD_SDK_KEY=sdk-1234567890abcdef
CONFIG_LD_TEST_FLAGS_FILE=

CONFIG_REDIS_DISABLE_TLS=false
CONFIG_REDIS_DISABLE_TLS_REJECT_UNAUTHORIZED=false
CONFIG_REDIS_EC_CLUSTER=my-redis-cluster
CONFIG_REDIS_HOST=redis.example.com
CONFIG_REDIS_USERNAME=redis_user
CONFIG_REDIS_PASSWORD=supersecurepassword123
CONFIG_REDIS_PORT=6379
CONFIG_REDIS_RECONNECT_MAX_WAIT=30000
CONFIG_REDIS_URL=redis://:supersecurepassword123@redis.example.com:6379
CONFIG_REDIS_KEY_PREFIX=""

CONFIG_WAREHOUSE_SERVICE_URL=http://warehouse-service:8000
CONFIG_WAREHOUSE_HEALTH_PATH=/api/health

CONFIG_AUTH_BASE_URL=http://auth-service:3001

CONFIG_KAFKA_BROKERS=localhost:9092
CONFIG_KAFKA_CLIENT_ID=workflow-service
CONFIG_KAFKA_GROUP_ID=workflow-service-group
CONFIG_KAFKA_SSL_ENABLED=false
CONFIG_KAFKA_SASL_USERNAME=
CONFIG_KAFKA_SASL_PASSWORD=
CONFIG_CASES_KAFKA_TOPIC=cases.v1
CONFIG_WORKFLOWS_KAFKA_TOPIC=workflows.v1
CONFIG_NOTIFICATIONS_KAFKA_TOPIC=notifications.v1
CONFIG_BUSINESS_KAFKA_TOPIC=business.v1

CONFIG_EXPORT_MAX_RECORDS=5000

# Frontend CORS Configuration
CONFIG_FRONTEND_LOCAL_BASE_URLS=http://localhost:5179,http://localhost:5177,http://localhost:5176,http://localhost:5178

# Health check mode: When true, the app verifies connectivity to all dependencies
# (DB, Kafka, Redis) without actually consuming Kafka messages or processing Bull
# queue jobs. Used in CI/CD pipelines for pre-deployment verification.
CONFIG_HEALTH_CHECK_MODE=false
