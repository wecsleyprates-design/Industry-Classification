# =============================================================================
# Workflow Service .gitignore
# =============================================================================

# =============================================================================
# Logs
# =============================================================================
logs/
logs/development/
logs/production/express/*
logs/production/server/*
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Exception to the logs rule - keep directory structure
!logs/production/server/.gitkeep
!logs/production/express/.gitkeep

# =============================================================================
# Runtime data
# =============================================================================
pids
*.pid
*.seed
*.pid.lock

# =============================================================================
# Dependencies
# =============================================================================
node_modules/
jspm_packages/
web_modules/

# =============================================================================
# Build outputs and compiled files
# =============================================================================
dist/
build/Release
*.tsbuildinfo
tsconfig.tsbuildinfo

# =============================================================================
# Coverage and testing
# =============================================================================
coverage/
coverage.txt
junit.xml
*.lcov

# Test results
junit.xml
coverage.txt

# nyc test coverage
.nyc_output
lib-cov

# =============================================================================
# Cache directories
# =============================================================================
.npm
.eslintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.cache
.parcel-cache
.fusebox/

# =============================================================================
# Framework-specific build outputs
# =============================================================================
# Next.js
.next

# Nuxt.js
.nuxt

# Gatsby
.cache/
# public

# VuePress
.vuepress/dist

# Storybook
.out
.storybook-out

# =============================================================================
# Environment and configuration files
# =============================================================================
.env
.env.local
.env.test
.env.production

# =============================================================================
# Data and file storage
# =============================================================================
.data/files/*
.data/tests/*
.data/docker/*

# Exception to the Data rule - keep directory structure
!.data/files/.gitkeep
!.data/docker/.gitkeep

# =============================================================================
# Security and keys
# =============================================================================
keys/access_token/*
keys/refresh_token/*
docker_password.txt

# Exception to the keys rule - keep directory structure
!keys/access_token/.gitkeep
!keys/refresh_token/.gitkeep

# =============================================================================
# Database and migrations
# =============================================================================
# Exception to the migration folder - keep directory structure
!db/migrations/.gitkeep

# =============================================================================
# Package managers
# =============================================================================
# npm
*.tgz
.yarn-integrity

# =============================================================================
# Development tools
# =============================================================================
# Grunt
.grunt

# Bower
bower_components

# node-waf
.lock-wscript

# =============================================================================
# REPL and debugging
# =============================================================================
.node_repl_history
.tern-port

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# =============================================================================
# Serverless and cloud
# =============================================================================
.serverless/
.dynamodb/

# =============================================================================
# IDE and editor files
# =============================================================================
.vscode-test
.idea/
*.swp
*.swo

# =============================================================================
# Operating system files
# =============================================================================
# macOS
.DS_Store
.DS_Store?

# Windows
Thumbs.db

# =============================================================================
# Temporary files and directories
# =============================================================================
tmp/
temp/

# =============================================================================
# Feature flags and local configuration
# =============================================================================
feature_flags.json

# =============================================================================
# WARP
# =============================================================================
WARP.md
